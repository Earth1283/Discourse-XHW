xhw.example.edu {
    encode zstd gzip

    # Serve uploaded images directly from disk — skip Node for static assets
    handle_path /uploads/* {
        root * /srv/xhw/uploads
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Proxy everything else to Next.js
    reverse_proxy 127.0.0.1:3000 {
        # Pass real client IP so rate limiting and IP-hash bans work correctly.
        # Caddy is the ONLY thing allowed to set X-Forwarded-For here.
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}
    }
}

# --- Database ---
DATABASE_URL=./data/xhw.db

# --- Auth / crypto (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))") ---
SESSION_SECRET=replace-me
IP_HASH_SALT=replace-me
TRIPCODE_SALT=replace-me

# --- Master admin (seeded on first boot) ---
ADMIN_HANDLE=admin
ADMIN_PASSWORD=change-this-now

# --- Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=8388608
MAX_IMAGE_DIM=2000

# --- Board behavior ---
MAX_LIVE_THREADS_PER_BOARD=100
SELF_DELETE_WINDOW_MS=10800000

# --- Rate limits ---
RL_POST_PER_MIN=4
RL_THREAD_PER_10MIN=3
RL_UPLOAD_PER_MIN=4
